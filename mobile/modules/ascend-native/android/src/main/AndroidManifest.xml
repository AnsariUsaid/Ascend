<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

  <!--
    These two permissions are declared here, in the module's manifest, and get
    MERGED into the app's AndroidManifest at build time. Both are "special":
    declaring them isn't enough — the user must also flip a switch in Settings
    (which is what openUsageAccessSettings / openOverlaySettings take them to).
  -->

  <!-- Read per-app foreground usage time (UsageStatsManager). Lint flags this as
       a protected permission; tools:ignore silences that since it's intentional. -->
  <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
                   tools:ignore="ProtectedPermissions" />

  <!-- Draw the friction screen over other apps. -->
  <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

  <!-- See other launchable apps (for the app picker) on Android 11+. This is the
       Play-Store-friendly alternative to QUERY_ALL_PACKAGES: it only reveals apps
       that have a launcher icon. -->
  <queries>
    <intent>
      <action android:name="android.intent.action.MAIN" />
      <category android:name="android.intent.category.LAUNCHER" />
    </intent>
  </queries>

</manifest>
