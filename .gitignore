# Dependencies
node_modules/

# Expo / Metro
.expo/
dist/
web-build/
*.tsbuildinfo

# Native projects: we COMMIT android/ (we hand-edit its manifest, gradle, and
# native code for M4). Build artifacts inside it are excluded by mobile/android/.gitignore.
# ios/ stays ignored — this is an Android-only app.
ios/
*.orig.*

# Env
.env*.local
.env

# Misc
.DS_Store
*.log
npm-debug.*
yarn-error.*

# Local archives
*.zip

# Design handoff — local reference only, not part of the codebase (changes
# frequently and shouldn't clutter commits). Kept on disk, untracked.
design_handoff_ascend_app 2/
AGENTS.md

# Session notes — local "brain dump" + logbook to spin up a fresh session fast.
# Kept on disk, untracked (docs/CHANGELOG.md is the committed record).
# Anchored to root so mobile/CLAUDE.md (the Expo notes stub) stays tracked.
docs/HANDOFF.md
/CLAUDE.md